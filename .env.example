DB_HOST=db
DB_PORT=5432
DB_DATABASE=paramascotasec
DB_USERNAME=postgres
DB_PASSWORD=change-this-to-a-strong-password

DEFAULT_TENANT=paramascotasec
JWT_SECRET=change-me-to-a-long-random-secret
JWT_SECRET_PREVIOUS=
INTERNAL_PROXY_TOKEN=replace-with-shared-internal-proxy-token
INTERNAL_PROXY_TOKEN_PREVIOUS=
AUTH_COOKIE_NAME=pm_auth
AUTH_CSRF_COOKIE_NAME=pm_csrf
AUTH_COOKIE_TTL_SECONDS=10800
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15
# off | private | custom
ADMIN_IP_MODE=private
ADMIN_IP_ALLOWLIST=
TRUST_PROXY_HEADERS=true
SERVICE_TOKEN_TTL=86400

APP_ENV=production
APP_URL=https://api.paramascotasec.com

MAIL_FROM_ADDRESS=no-reply@paramascotasec.com
MAIL_FROM_NAME="Para Mascotas EC"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
ADMIN_MFA_FALLBACK_EMAIL=

FACTURADOR_API_URL=http://facturador
FACTURADOR_TIMEOUT=20
FACTURADOR_API_KEY=
